# ═══════════════════════════════════════════════════
# KCY Ecosystem - Global Configuration (.env)
# ═══════════════════════════════════════════════════
# Глобален файл за ВСИЧКИ проекти в екосистемата.
# Живее в: private/configs/.env
# НЕ го качвай в git!
#
# Chat и ECO-3 го четат чрез symlink:
#   chat/configs/.env    → ../../configs/.env
#   eco-3/configs/.env   → ../../configs/.env
# ═══════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────
NODE_ENV=production
CHAT_PORT=3000
ECO3_PORT=3001
ALLOWED_ORIGINS=http://localhost,https://alsec.strangled.net
# Админ достъп до Chat (трябват и 3-те):
#   1. URL параметър ?adm=bgmasters-set — показва админ бутоните
#   2. Логин: username=admin, password=admin123
#   3. IP-то ти трябва да е в списъка долу, иначе сървърът връща 403
ADMIN_ALLOWED_IPS=127.0.0.1,::1,0.0.0.0/0

# Public diagnostics bundle URL: https://server/last-errors-bundle
# Без IP restriction — пуска всички. Полезно за debug когато трябва Claude/curl да тегли логовете.
# По време на тест: true. След като production-ът работи стабилно: false (изключи).
PUBLIC_DIAG_BUNDLE=true

# ── Database (Chat) ─────────────────────────────────
# DB_TYPE: sqlite или postgresql
# 01-setup-database.sh попълва тези автоматично
DB_TYPE=sqlite
SQLITE_DB_FILE=database/amschat.db
# PostgreSQL (попълни само ако DB_TYPE=postgresql):
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=ams_chat_db
PG_USER=ams_chat_user
PG_PASSWORD=

# ── Database (ECO-3) ───────────────────────────────
ECO3_DB_PATH=database/eco3.db

# ── Stripe (споделен Chat + ECO-3 + Портали) ──────────────────
# https://dashboard.stripe.com/apikeys
#
# РЕЖИМ: STRIPE_TEST_MODE=1 → тестови (фалшиви карти) | =0 → live (реални пари)
# Сменяй САМО тази променлива — кодът избира правилните ключове/линкове.
STRIPE_TEST_MODE=1

# ── LIVE ключове (попълни реалните; НЕ ги качвай в публично repo) ──
STRIPE_SECRET_KEY_LIVE=sk_live_your_secret_key_here
STRIPE_PUBLISHABLE_KEY_LIVE=pk_live_your_publishable_key_here
# ── TEST ключове (фалшиви карти: 4242 4242 4242 4242) ──
STRIPE_SECRET_KEY_TEST=sk_test_your_secret_key_here
STRIPE_PUBLISHABLE_KEY_TEST=pk_test_your_publishable_key_here

# ── LIVE Payment Links ──
STRIPE_PAYMENT_LINK_CHAT_LIVE=https://buy.stripe.com/aFa14m4ZI8bE7Qh7S7aMU00
STRIPE_PAYMENT_LINK_PORTALS_LIVE=https://buy.stripe.com/28E4gy3VE63w9YpegvaMU01
STRIPE_PAYMENT_LINK_ECO3_ECONOMY_LIVE=https://buy.stripe.com/14AcN4eAibnQdaBegvaMU02
STRIPE_PAYMENT_LINK_ECO3_STANDARD_LIVE=https://buy.stripe.com/14A3cueAieA23A12xNaMU03
STRIPE_PAYMENT_LINK_ECO3_PREMIUM_LIVE=https://buy.stripe.com/9B64gyeAi1NgeeFb4jaMU04
STRIPE_PAYMENT_LINK_ECO3_ENTERPRISE_LIVE=https://buy.stripe.com/28E7sK1Nw3Vo6MdfkzaMU05

# ── TEST Payment Links ──
STRIPE_PAYMENT_LINK_CHAT_TEST=https://buy.stripe.com/test_14A8wObpF3fsdkLgiR4AU03
STRIPE_PAYMENT_LINK_PORTALS_TEST=https://buy.stripe.com/test_7sYaEW0L14jw6Wn2s14AU00
STRIPE_PAYMENT_LINK_ECO3_ECONOMY_TEST=https://buy.stripe.com/test_9B6cN4alB03g1C31nX4AU02
STRIPE_PAYMENT_LINK_ECO3_STANDARD_TEST=https://buy.stripe.com/test_3cIeVc3Xd2bo80raYx4AU04
STRIPE_PAYMENT_LINK_ECO3_PREMIUM_TEST=https://buy.stripe.com/test_14AbJ0eBR8zM94vgiR4AU05
STRIPE_PAYMENT_LINK_ECO3_ENTERPRISE_TEST=https://buy.stripe.com/test_9B6eVc2T93fsa8z3w54AU06

# ── Anthropic API (ECO-3) ───────────────────────────
#
# КАКВО Е ТОВА:
#   Ключ за достъп до Claude AI (програмно, не през чат).
#   ОТДЕЛНО е от абонамента за Claude.ai — плаща се по usage.
#
# ОТКЪДЕ СЕ ВЗЕМА:
#   1. https://console.anthropic.com
#   2. Влез или създай акаунт (може със същия email)
#   3. Settings → API Keys → Create Key
#   4. Копирай ключа (започва с sk-ant-)
#
# КОЛКО СТРУВА:
#   Нов акаунт = $5 безплатен кредит
#   1 търсене в ECO-3 (3 агента) ≈ $0.01-0.05
#   $5 кредит ≈ стотици търсения
#   Баланс: https://console.anthropic.com/settings/billing
#
# ВАЖНО: ключът е ТАЕН, не го качвай в git!
#
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── ECO-3 Режим ───────────────────────────────────
# test       = безплатно, mock данни, НЕ вика Anthropic API
# production = реални заявки, ПЛАЩА СЕ по usage
ECO3_MODE=test

# ── Blockchain / Token deploy ────────────────────────
# Wallet private key за deploy на smart contracts (Token, MultiSig)
# https://docs.bnbchain.org/docs/
PRIVATE_KEY=
BSCSCAN_API_KEY=
BSC_TESTNET_RPC=https://data-seed-prebsc-1-s1.binance.org:8545/
BSC_MAINNET_RPC=https://bsc-dataseed.binance.org/

# ── Security ─────────────────────────────────────────
# 01-setup-database.sh ги генерира автоматично
JWT_SECRET=
SESSION_SECRET=

# ── Portals (Games + Services) ───────────────────────
# Нов subproject: private/portals/
# Games портал + Services портал (AI обява за имот + Web скрапер).
# Споделя ANTHROPIC_API_KEY с ECO-3 и ADMIN_ALLOWED_IPS с Chat/ECO-3.
PORTALS_PORT=3002
PORTALS_DB_PATH=database/portals.db
PORTALS_SESSION_SECRET=change-me-to-a-long-random-string

# ── Testing (не пипай за production) ─────────────────
# TEST_MODE=true
# TEST_DB=amschat_test.db
# REPORT_GAS=true

# ── CoinMarketCap (ранг на криптовалутите в watch20) ──
# Безплатен Basic ключ от https://coinmarketcap.com/api → Developer Portal.
# Без него watch20 просто не показва ранг-бадж (не лъже с друг източник).
CMC_API_KEY=your_coinmarketcap_api_key_here

# ── Google Custom Search (House-Look-Book: форми по изображения) ──
# Безплатно до 100 търсения/ден. Как се вземат — виж docs/API-KEYS.md (т.3).
#   API_KEY → console.cloud.google.com (Custom Search API → Credentials)
#   CX      → programmablesearchengine.google.com (Search engine ID)
# Без тях: качването на СВОЯ снимка за форма пак работи (Google е само за авто-търсене).
HLB_GOOGLE_API_KEY=your_google_api_key_here
HLB_GOOGLE_CX=your_search_engine_id_here
