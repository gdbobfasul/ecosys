# ═══════════════════════════════════════════════════
# KCY Ecosystem - Global Configuration (.env)
# ═══════════════════════════════════════════════════
# Глобален файл за ВСИЧКИ проекти в екосистемата.
# Живее в: private/configs/.env
# НЕ го качвай в git!
#
# Chat и ECO-3 го четат чрез symlink:
#   chat/configs/.env    → ../../configs/.env
#   eco-3/configs/.env   → ../../configs/.env
# ═══════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────
NODE_ENV=production
CHAT_PORT=3000
ECO3_PORT=3001
ALLOWED_ORIGINS=http://localhost,https://alsec.strangled.net
ADMIN_ALLOWED_IPS=127.0.0.1,::1

# ── Database (Chat) ─────────────────────────────────
# DB_TYPE: sqlite или postgresql
# 01-setup-database.sh попълва тези автоматично
DB_TYPE=sqlite
# PostgreSQL (попълни само ако DB_TYPE=postgresql):
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=ams_chat_db
PG_USER=ams_chat_user
PG_PASSWORD=

# ── Database (ECO-3) ───────────────────────────────
# Когато ECO-3 получи база данни, ще ползва тези:
ECO3_DB_TYPE=sqlite
# PostgreSQL за ECO-3:
# ECO3_DB_TYPE=postgresql
# ECO3_PG_HOST=localhost
# ECO3_PG_PORT=5432
# ECO3_PG_DATABASE=eco3_db
# ECO3_PG_USER=eco3_user
# ECO3_PG_PASSWORD=

# ── Stripe (споделен Chat + ECO-3) ──────────────────
# https://dashboard.stripe.com/apikeys
# ВАЖНО: Един и същ ключ за Chat и ECO-3!
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# ── Anthropic API (ECO-3) ───────────────────────────
# https://console.anthropic.com → Settings → API Keys
# Без този ключ ECO-3 не може да генерира съдържание
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Blockchain / Token deploy ────────────────────────
# Wallet private key за deploy на smart contracts (Token, MultiSig)
# https://docs.bnbchain.org/docs/
PRIVATE_KEY=
BSCSCAN_API_KEY=
BSC_TESTNET_RPC=https://data-seed-prebsc-1-s1.binance.org:8545/
BSC_MAINNET_RPC=https://bsc-dataseed.binance.org/

# ── Security ─────────────────────────────────────────
# 01-setup-database.sh ги генерира автоматично
JWT_SECRET=
SESSION_SECRET=

# ── Testing (не пипай за production) ─────────────────
# TEST_MODE=true
# TEST_DB=amschat_test.db
# REPORT_GAS=true
