# KCY Ecosystem - npm configuration
# legacy-peer-deps=true → казва на npm да пренебрегне strict peer-dependency
# проверките. Нужно е заради конфликта между react-native 0.73 и новите версии
# на react-native-screens / @react-navigation. Server-install.sh използва същия флаг.
legacy-peer-deps=true
