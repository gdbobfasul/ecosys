{
  "appId": "com.kcy.selflearningfriend.rustore",
  "appName": "Pupikes LB",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "allowMixedContent": false
  },
  "plugins": {
    "CapacitorHttp": { "enabled": true },
    "BackgroundRunner": {
      "label": "com.kcy.selflearningfriend.rustore.learn",
      "src": "runners/learn-runner.js",
      "event": "learnTick",
      "repeat": true,
      "interval": 120,
      "autoStart": false
    }
  }
}
