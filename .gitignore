# Environment & Secrets
.env
.env.local
.env.production
configs/.env
configs/.env.local
configs/.env.production

# Version tracking files (INCLUDE in Git)
# *.version files are tracked

# Database
*.db
*.db-journal
*.db-shm
*.db-wal

# Dependencies
node_modules/
package-lock.json
yarn.lock

# Uploads & User Data
uploads/*
!uploads/.gitkeep
patch/*

# Logs — папката е проследена САМО заради README (конвенцията); реалните логове се игнорират.
logs/*
!logs/README.md
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pm2-*.log

# Testing
coverage/
.nyc_output/
test-*.db

# OS Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Editor directories and files
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*~

# Build outputs
dist/
build/
out/

# Hardhat
private/token/cache/
private/multisig/cache/
private/token/artifacts/
private/multisig/artifacts/

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.swp
*.swo

# Mobile specific (if using React Native)
android/
ios/
*.xcworkspace
*.xcodeproj

# Sensitive files
*.pem
*.key
*.cert
id_rsa*
credentials.json
service-account.json

# Old files backup (temporary)
/old
old/
.deploy-targets

# Тест робот — репорти, логове и локални node_modules (не в git)
private/robot/reports/
private/robot/robot-logs/
private/robot/node_modules/

# Анимации/видеа — огромни (~610 MB), стоят само локално на диска и се деплойват
# отделно (НЕ през git). Махнати от цялата git история с filter-repo. НЕ ги връщай в git.
public/assets/animations/
# (raw/ оригиналите така или иначе са вътре в горната папка)
public/assets/animations/raw/
*.rar
# големи видеа архиви
assets-update.zip
green-originals*.zip
green-videos*.zip

# token-creator — деплой записи + локални модули
private/token-creator/deployments/
private/token-creator/node_modules/

# token-protector — аларми + локални модули
private/token-protector/alerts/
private/token-protector/node_modules/

# обща node_modules за роботите (token-creator/protector/robot) — не в git
node_modules2/

# Мобилни апове (rustore/huawei) — БИНАРНИ build артефакти, не в git.
# (node_modules/ dist/ android/ ios/ вече са покрити глобално по-горе — пази се само сорсът.)
*.apk
*.aab
*.keystore
*.jks
# /apk — папката на pupikes.app: каталог (index.html/catalog.json/лого) + инсталируемите
# файлове. В git се пазят каталогът и README; игнорират се САМО бинарните .apk/.exe.
/apk/*.exe
# тест-робот скрийншоти (опции 58/59)
deploy-scripts/play-reports/
# Тежки видео/медийни активи, вендорнати в мобилните апове (напр. DUEL ~180MB/ап) —
# локални, бъндълват се при билд (влизат в APK), НЕ в git (като public/assets/animations/)
rustore/**/assets/animations/
huawei/**/assets/animations/
/keystores/

# Локални отговори от опция 2 (пълна инсталация) — не в git
.full-install-answers
apk/versions.json

# Pupikes Doctor — свалена референтна снимкова библиотека (~4.5GB, скрапната от ISIC/Wikipedia/
# Open-i/Commons). Сервира се/сваля се от сървъра, НЕ влиза в git и НЕ в APK. Регенерируема
# от private/medikit-harvester/*. Индексът също (манифест на игнорираните снимки).
rustore/**/publish/reference/images/
huawei/**/publish/reference/images/
rustore/**/publish/reference/images-index.json
huawei/**/publish/reference/images-index.json
