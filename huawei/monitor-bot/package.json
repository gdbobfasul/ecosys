    "@capacitor/filesystem": "^6.0.4",
    "@capacitor/local-notifications": "^6.0.1",
    "@capacitor/preferences": "^6.0.2"
  },
  "devDependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/cli": "^6.2.1",
    "vite": "^5.4.10"
  }
